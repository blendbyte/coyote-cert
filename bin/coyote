#!/usr/bin/env php
<?php

// Support both standalone repo and composer global/local installs
foreach ([
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
] as $autoload) {
    if (file_exists($autoload)) {
        require $autoload;
        break;
    }
}

use CoyoteCert\Console\Application;

exit((new Application())->run());
