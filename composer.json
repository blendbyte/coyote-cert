{
  "name": "blendbyte/coyote-cert",
  "description": "ACME v2 (Let's Encrypt) certificate client library for PHP.",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "psr/log": "^3.0",
    "spatie/dns": "^2.5"
  },
  "require-dev": {
    "larapack/dd": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "CoyoteCert\\": "src"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "config": {
    "sort-packages": true
  }
}
